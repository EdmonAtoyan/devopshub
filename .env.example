DATABASE_URL="postgresql://postgres:postgres@localhost:5432/devops_community?schema=public"
REDIS_URL="redis://localhost:6379"
MEILI_URL="http://localhost:7700"
MEILI_MASTER_KEY="devops-community-key"
JWT_SECRET="replace-me"

# Use same-origin API path in the browser.
NEXT_PUBLIC_API_URL="/api"
NEXT_PUBLIC_SITE_URL="http://192.168.1.10:3000"
RESET_PASSWORD_BASE_URL="http://192.168.1.10:3000"
# Optional server-side proxy target for Next.js rewrites (/api and /uploads).
# API_UPSTREAM_URL="http://192.168.1.10:4000"

# Supports explicit origins and wildcard rules.
CORS_ORIGIN="http://localhost:3000,http://192.168.1.10:3000,https://*.ngrok-free.app,https://*.ngrok-free.dev,https://*.ngrok.app"

# Optional cookie overrides for cross-site/public deployments.
# COOKIE_SAME_SITE="none"
# COOKIE_SECURE="true"
# COOKIE_DOMAIN=".example.com"
