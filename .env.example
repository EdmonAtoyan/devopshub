# Core runtime settings for local development and production containers.
JWT_SECRET="replace-with-a-long-random-secret"
DATABASE_URL="postgresql://devops:devops@localhost:5432/devopshub?schema=public"
# For managed PostgreSQL, append `&sslmode=require` when TLS is required.
# DATABASE_URL="postgresql://USERNAME:PASSWORD@db.example.amazonaws.com:5432/devopshub?schema=public&sslmode=require"

# Local defaults:
# - web: http://localhost:3000
# - api: http://localhost:4000
PORT="3000"
API_PORT="4000"

# Browser calls stay same-origin in every environment.
NEXT_PUBLIC_API_URL="/api"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
RESET_PASSWORD_BASE_URL="http://localhost:3000"
EMAIL_VERIFICATION_BASE_URL="http://localhost:3000"

# Optional server-side proxy target used by the Next.js app for /api, /uploads, and /socket.io.
# Local default if omitted: http://127.0.0.1:4000
# Kubernetes example: http://api:4000
# API_UPSTREAM_URL="http://127.0.0.1:4000"

# Keep this aligned with the public site origin. Add extra origins as a comma-separated list if needed.
CORS_ORIGIN="http://localhost:3000"
# Set this to "true" only when you intentionally want wildcard ngrok support outside local development.
# ALLOW_NGROK_ORIGINS="false"

# Optional Google OAuth.
# The callback defaults to ${NEXT_PUBLIC_SITE_URL}/api/auth/google/callback.
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# GOOGLE_CALLBACK_URL="http://localhost:3000/api/auth/google/callback"

# Optional Giphy GIF search for posts and comments.
# GIPHY_API_KEY=""

# Configure either SMTP_* or RESEND_* for real email delivery.
# Optional: force password reset links to be logged even outside local development.
# LOG_PASSWORD_RESET_LINKS="true"
# RESEND_API_KEY=""
# RESEND_FROM="DevOps Hub <no-reply@example.com>"
# SMTP_HOST="smtp.sendgrid.net"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER="your-email@example.com"
# SMTP_PASS="your_app_password"
# SMTP_FROM="DevOps Hub <no-reply@example.com>"
# SMTP_REPLY_TO="support@example.com"

# Optional CAPTCHA protection.
# CAPTCHA_PROVIDER="turnstile"
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
# TURNSTILE_SECRET_KEY=""
# NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""
# RECAPTCHA_SECRET_KEY=""

# Optional cookie overrides for custom domains or cross-site deployments.
# COOKIE_SAME_SITE="none"
# COOKIE_SECURE="true"
# COOKIE_DOMAIN=".example.com"
