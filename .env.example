# Minimal secrets for the Docker Compose deployment:
SMTP_PASS=your_gmail_app_password
JWT_SECRET=your_jwt_secret

POSTGRES_USER="devops"
POSTGRES_PASSWORD="devops"
POSTGRES_DB="devopshub"
DATABASE_URL="postgresql://devops:devops@localhost:5432/devopshub?schema=public"
# For AWS + RDS, append `&sslmode=require` if your database requires TLS.
# DATABASE_URL="postgresql://USERNAME:PASSWORD@db.example.amazonaws.com:5432/devopshub?schema=public&sslmode=require"
# Redis is not required for the current standalone deployment.
# REDIS_URL="redis://localhost:6379"
# Replace this before any shared, staging, or production deployment.
API_PORT="3001"
# Optional standalone web port. Defaults to 3000 when omitted.
# PORT="3000"

# Use same-origin API path in the browser.
NEXT_PUBLIC_API_URL="/api"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
RESET_PASSWORD_BASE_URL="http://localhost:3000"
EMAIL_VERIFICATION_BASE_URL="http://localhost:3000"
# Optional Google OAuth for "Continue with Google" login/signup.
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# GOOGLE_CALLBACK_URL="http://localhost:3001/api/auth/google/callback"
# For EC2 or any public deployment, replace the localhost values above with your public site URL.
# Example:
# NEXT_PUBLIC_SITE_URL="http://YOUR_EC2_PUBLIC_IP:3000"
# RESET_PASSWORD_BASE_URL="http://YOUR_EC2_PUBLIC_IP:3000"
# EMAIL_VERIFICATION_BASE_URL="http://YOUR_EC2_PUBLIC_IP:3000"
# Optional server-side proxy target for Next.js rewrites (/api, /uploads, and /socket.io).
# API_UPSTREAM_URL="http://127.0.0.1:3001"
# Optional Giphy GIF search for posts and comments.
# GIPHY_API_KEY=""
# Configure either SMTP_* or RESEND_* for real email delivery.
# Optional: force password reset links to be logged even outside local development.
# LOG_PASSWORD_RESET_LINKS="true"
# CAPTCHA_PROVIDER="turnstile"
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
# TURNSTILE_SECRET_KEY=""
# NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""
# RECAPTCHA_SECRET_KEY=""
# RESEND_API_KEY=""
# RESEND_FROM="DevOps Hub <no-reply@example.com>"
# SMTP_HOST="smtp.sendgrid.net"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER="your-gmail-address@gmail.com"
# SMTP_PASS="your_gmail_app_password"
# SMTP_FROM="DevOps Hub <your-gmail-address@gmail.com>"
# SMTP_REPLY_TO="support@example.com"
# Supports explicit origins and wildcard rules. For production, set this to your public site origin.
CORS_ORIGIN="http://localhost:3000,https://*.ngrok-free.app,https://*.ngrok-free.dev,https://*.ngrok.app"
# Set this to "false" in shared or production environments unless you explicitly need ngrok access.
# ALLOW_NGROK_ORIGINS="false"

# Optional cookie overrides for cross-site/public deployments.
# COOKIE_SAME_SITE="none"
# COOKIE_SECURE="true"
# COOKIE_DOMAIN=".example.com"
