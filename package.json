{
  "name": "devops-community-platform",
  "private": true,
  "version": "0.1.0",
  "description": "Kubernetes-first DevOps community platform",
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace @devops-community/web run dev",
    "dev:api": "npm --workspace @devops-community/api run start:dev",
    "build": "npm run db:generate && npm run build:web && npm run build:api",
    "build:web": "npm --workspace @devops-community/web run build",
    "build:api": "npm --workspace @devops-community/api run build",
    "start:standalone": "node scripts/start-standalone.mjs",
    "docker:build": "npm run docker:build:api && npm run docker:build:web",
    "docker:build:api": "docker build -f apps/api/Dockerfile -t devops-community-api .",
    "docker:build:web": "docker build -f apps/web/Dockerfile -t devops-community-web .",
    "lint": "npm run lint:web && npm run lint:api",
    "lint:web": "npm --workspace @devops-community/web run lint",
    "lint:api": "npm --workspace @devops-community/api run lint",
    "db:generate": "npm --workspace @devops-community/api exec -- prisma generate --schema ../../prisma/schema.prisma",
    "db:migrate:deploy": "npm --workspace @devops-community/api exec -- prisma migrate deploy --schema ../../prisma/schema.prisma",
    "db:migrate": "npm --workspace @devops-community/api exec -- prisma migrate dev --schema ../../prisma/schema.prisma",
    "db:studio": "npm --workspace @devops-community/api exec -- prisma studio --schema ../../prisma/schema.prisma"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1"
  }
}
